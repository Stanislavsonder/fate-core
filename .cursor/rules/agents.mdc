## Anti-Patterns to Avoid

### ❌ Don't Do These

```typescript
// ❌ Avoid direct DOM manipulation
document.getElementById('element').innerHTML = 'content'

// ❌ Avoid mutating props directly
props.character.name = 'New Name'

// ❌ Avoid tight coupling between modules
import { SomeOtherModule } from '@/modules/other-module'

// ❌ Avoid using any type
const data: any = getData()

// ❌ Avoid ignoring errors
try {
  riskyOperation()
} catch {
  // Silent failure
}

// ❌ Avoid massive components
// Components should be < 300 lines

// ❌ Avoid deep nesting in templates
<div>
  <div>
    <div>
      <div>
        <div>
          <!-- Too deep -->
        </div>
      </div>
    </div>
  </div>
</div>

// ❌ Module-specific anti-patterns
// Don't use props/emits in module root components
interface Props {
  character: Character
  config: ModuleConfig
}
const props = defineProps<Props>()
const emit = defineEmits<ComponentEmits>()

// ❌ Don't store module data in _modules
character._modules[moduleId] = { moduleData: 'value' }

// ❌ Don't import constants directly in components
import { MODULE_ID, CONSTANT } from './constants'

// ❌ Don't include MODULE_ID in constants
const constants = {
  MODULE_ID: 'sonder@module-name',
  OTHER_CONSTANT: 'value'
}

// ❌ Don't use custom wrappers instead of SheetSection
<div class="custom-module-wrapper">
  <h3>Module Title</h3>
  <!-- content -->
</div>

// ❌ Don't access module data through _modules in components
const moduleData = character._modules[moduleId]?.data

// ❌ Don't use 'modules.' prefix in translation keys
{{ $t('modules.sonder@module-name.fields.fieldName') }}
```

### ✅ Do These Instead

```typescript
// ✅ Use Vue refs for DOM access
const elementRef = ref<HTMLElement>()

// ✅ Emit events for prop changes
emit('update:character', { ...props.character, name: 'New Name' })

// ✅ Use shared context for module communication
context.shared.moduleData = someData

// ✅ Use proper typing
const data: ApiResponse = await getData()

// ✅ Handle errors appropriately
try {
  await riskyOperation()
} catch (error) {
  handleError(error)
}

// ✅ Break large components into smaller ones
// Each component should have a single responsibility

// ✅ Use composition to reduce nesting
<template>
  <card-wrapper>
    <card-header />
    <card-content />
    <card-footer />
  </card-wrapper>
</template>

// ✅ Module-specific correct patterns
// Use defineModel and inject for module components
const character = defineModel<Character>({ required: true })
const context = inject<Ref<FateContext>>('context')!

// ✅ Store module data directly on character
character.value.moduleData = { field: 'value' }

// ✅ Access constants through context
const maxValue = context.value.constants.MAX_VALUE!

// ✅ Use Pick<FateConstants> for module constants
const constants: Pick<FateConstants, 'CONSTANT1' | 'CONSTANT2'> = {
  CONSTANT1: 'value1',
  CONSTANT2: 'value2'
}

// ✅ Use SheetSection wrapper component
<SheetSection :title="$t('modules.module-name.name')">
  <Button @click="action">{{ $t('actions.save') }}</Button>
</SheetSection>

// ✅ Access module data directly on character
const moduleData = character.value.moduleData

// ✅ Use correct translation key pattern without 'modules.' prefix
{{ $t('sonder@module-name.fields.fieldName') }}
```

## Troubleshooting

### Common Issues

#### Module Loading Failures

```typescript
// Problem: Module fails to load
// Solution: Check module manifest and dependencies

export function debugModuleLoading(moduleId: string) {
	const module = Modules.get(moduleId)
	if (!module) {
		console.error(`Module ${moduleId} not found in registry`)
		return
	}

	console.log('Module manifest:', module)
	console.log('Dependencies:', module.dependencies)
	console.log('App version compatibility:', module.appVersion)
}
```

#### State Synchronization Issues

```typescript
// Problem: State not updating across components
// Solution: Check reactivity and use proper refs

// ❌ Non-reactive assignment
let character = getCharacter()

// ✅ Reactive reference
const character = ref(getCharacter())
```

#### Performance Issues

```typescript
// Problem: Slow rendering with large datasets
// Solution: Use virtual scrolling and pagination

// ✅ Paginated data loading
const usePaginatedData = (pageSize = 20) => {
	const currentPage = ref(1)
	const data = ref([])

	const loadPage = async (page: number) => {
		const results = await api.getData({
			page,
			limit: pageSize
		})
		data.value = results
	}

	return { currentPage, data, loadPage }
}
```

