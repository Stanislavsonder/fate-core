## Component Development

### Component Structure

```vue
<script setup lang="ts">
// ✅ Imports first
import { ref, computed, watch } from 'vue'
import { IonButton, IonInput } from '@ionic/vue'
import type { Character } from '@/types'

// ✅ Props and emits
interface Props {
	character: Character
	readonly?: boolean
}

interface Emits {
	update: [character: Character]
	delete: [id: number]
}

const { character, readonly = false } = defineProps<Props>()

const emit = defineEmits<Emits>()

// ✅ Local state
const isEditing = ref(false)
const localCharacter = ref({ ...character })

// ✅ Computed properties
const isValid = computed(() => localCharacter.value.name.length > 0)

// ✅ Methods
const saveChanges = () => {
	emit('update', localCharacter.value)
	isEditing.value = false
}

// ✅ Watchers
watch(
	() => props.character,
	newCharacter => {
		localCharacter.value = { ...newCharacter }
	},
	{ deep: true }
)
</script>

<template>
	<!-- ✅ Clean, semantic template -->
	<div class="character-card p-4 rounded-lg shadow">
