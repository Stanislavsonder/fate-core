## Database & Storage

### Dexie.js Integration

```typescript
// ✅ Database schema definition
import Dexie, { type Table } from 'dexie'
import type { Character } from '@/types'

export class FateDatabase extends Dexie {
	characters!: Table<Character>

	constructor() {
		super('FateDatabase')
		this.version(1).stores({
			characters: '++id, name, _version'
		})
	}
}

export const db = new FateDatabase()
```

### Data Access Patterns

```typescript
// ✅ Service layer for data access
export class CharacterService {
	async createCharacter(character: Omit<Character, 'id'>): Promise<Character> {
		const id = await db.characters.add(character as Character)
		return { ...character, id } as Character
	}

	async getCharacter(id: number): Promise<Character | undefined> {
		return await db.characters.get(id)
	}

	async updateCharacter(character: Character): Promise<Character> {
		await db.characters.put(character)
		return character
	}

	async deleteCharacter(id: number): Promise<void> {
		await db.characters.delete(id)
	}

	async getAllCharacters(): Promise<Character[]> {
		return await db.characters.toArray()
	}
}
```

### Data Validation

```typescript
// ✅ Validate data before storage
export function validateCharacter(character: unknown): character is Character {
	return (
		typeof character === 'object' && character !== null && typeof (character as Character).name === 'string' && typeof (character as Character).id === 'number'
	)
}
