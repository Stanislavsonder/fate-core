## Module Development Patterns

### Module Constants Structure

Module constants should use the `Pick<FateConstants, ...>` pattern and avoid including metadata like `MODULE_ID` that's available in context:

```typescript
// ✅ Correct module constants pattern
import type { FateConstants } from '@/types'

const constants: Pick<FateConstants, 'DEFAULT_REFRESH' | 'MIN_REFRESH' | 'MAX_REFRESH'> = {
	DEFAULT_REFRESH: 3,
	MIN_REFRESH: 1,
	MAX_REFRESH: 10
}

export default constants
```

```typescript
// ❌ Don't include MODULE_ID in constants
const constants = {
	MODULE_ID: 'sonder@module-name' // Available in context
	// ... other constants
}
```

### Module Types with Declaration Merging

Extend global types using module declaration merging:

```typescript
// ✅ Extend global interfaces
import type { Character as _Character, FateConstants as _FateConstants } from '@/types'

declare module '@/types' {
	interface Character {
		moduleData?: {
			field1: string
			field2: number
		}
	}
	interface FateConstants {
		MODULE_CONSTANT?: number
		MODULE_CONFIG?: string
	}
}
```

### Module Actions Pattern

Module actions should store data directly on the character object and access constants through context:

```typescript
// ✅ Correct module actions pattern
import type { Character, FateContext } from '@/types'

export function onInstall(context: FateContext, character: Character): void {
	character.moduleData = character.moduleData ?? {
		field1: 'default',
		field2: context.constants.DEFAULT_VALUE!
	}
}

export function onUninstall(_context: FateContext, character: Character): void {
	delete character.moduleData
}
```

```typescript
// ❌ Don't store in _modules or import constants
import { MODULE_ID } from './constants' // Don't do this

export function onInstall(context: FateContext, character: Character): void {
	character._modules[MODULE_ID] = { ... } // Don't store here
}
```

### Module Component Pattern

Module components should use `defineModel` and `inject` instead of props/emits:

```typescript
// ✅ Correct module component pattern
<script setup lang="ts">
import { computed, inject, type Ref } from 'vue'
import type { Character, FateContext } from '@/types'
import SheetSection from '@/components/ui/SheetSection.vue'
import Button from '@/components/ui/Button.vue'

const character = defineModel<Character>({
	required: true
})

const context = inject<Ref<FateContext>>('context')!

const moduleData = computed(() => {
	return character.value.moduleData || { /* defaults */ }
})

const updateData = () => {
	if (!character.value.moduleData) {
		character.value.moduleData = { /* initial data */ }
	} else {
		character.value.moduleData.field1 = 'new value'
	}
}
</script>

<template>
	<SheetSection :title="$t('modules.module-name.name')">
		<!-- Module content -->
		<Button @click="updateData">
			{{ $t('modules.module-name.actions.update') }}
		</Button>
	</SheetSection>
</template>
```

```typescript
// ❌ Don't use props/emits for module components
interface Props {
	character: Character // Don't use props
	config: ModuleConfig
}

interface Emits {
	'character-updated': [character: Character] // Don't use emits
}

const props = defineProps<Props>()
const emit = defineEmits<Emits>()
```

