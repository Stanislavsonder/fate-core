// ✅ Module debugging utility
export function debugModule(moduleId: string) {
	const module = Modules.get(moduleId)

	console.group(`Module: ${moduleId}`)
	console.log('Manifest:', module?.manifest)
	console.log('Components:', module?.components)
	console.log('Constants:', module?.constants)
	console.log('Templates:', module?.templates)
	console.groupEnd()
}
