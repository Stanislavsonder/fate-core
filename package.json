{
	"name": "fate-core",
	"private": true,
	"version": "1.2.5",
	"repository": {
		"url": "https://github.com/Stanislavsonder/fate-core.git"
	},
	"engines": {
		"node": ">=24.14.0"
	},
	"author": {
		"name": "Stanislav Sonder",
		"email": "stanislavsonder@gmail.com"
	},
	"type": "module",
	"lint-staged": {
		"*.{js,ts,vue,json}": [
			"eslint .",
			"prettier --write"
		]
	},
	"packageManager": "pnpm@10.30.3",
	"scripts": {
		"dev": "pnpm compile-translation && vite --host",
		"translate": "node --experimental-transform-types ./scripts/localizer/index.ts",
		"build:android": "pnpm build && npx cap sync android && npx cap open android",
		"build:ios": "pnpm build && npx cap sync ios && npx cap open ios",
		"build": "pnpm compile-translation && vue-tsc && vite build",
		"preview": "vite preview",
		"test:e2e": "cypress run",
		"test:unit": "vitest",
		"postinstall": "cypress install",
		"lint": "eslint . --fix",
		"format": "prettier --write .",
		"test": "pnpm test:unit && pnpm test:e2e",
		"cypress:open": "cypress open",
		"prepare": "husky",
		"version-bump": "node --experimental-transform-types ./scripts/version-bump/index.ts",
		"version-bump:patch": "pnpm version-bump --patch",
		"version-bump:minor": "pnpm version-bump --minor",
		"version-bump:major": "pnpm version-bump --major",
		"compile-translation": "node --experimental-transform-types ./scripts/translation-compiler/index.ts",
		"module:generate": "node --experimental-transform-types ./scripts/module-generator/index.ts"
	},
	"dependencies": {
		"@capacitor/android": "8.1.0",
		"@capacitor/app": "8.0.1",
		"@capacitor/core": "8.0.1",
		"@capacitor/dialog": "8.0.1",
		"@capacitor/filesystem": "8.1.2",
		"@capacitor/haptics": "8.0.1",
		"@capacitor/ios": "8.1.0",
		"@capacitor/keyboard": "8.0.1",
		"@capacitor/motion": "8.0.0",
		"@capacitor/share": "8.0.1",
		"@capacitor/status-bar": "8.0.1",
		"@ionic/pwa-elements": "3.4.0",
		"@ionic/vue": "8.7.18",
		"@ionic/vue-router": "8.7.18",
		"@vueuse/core": "14.2.1",
		"cannon-es": "0.20.0",
		"cannon-es-debugger": "1.0.0",
		"dexie": "4.3.0",
		"ionicons": "8.0.13",
		"lodash": "4.17.23",
		"markdown-it": "14.1.1",
		"pinia": "3.0.4",
		"three": "0.183.1",
		"ts-node": "10.9.2",
		"vue": "3.5.29",
		"vue-i18n": "11.2.8",
		"vue-router": "5.0.3"
	},
	"devDependencies": {
		"@capacitor/cli": "8.1.0",
		"@commitlint/config-conventional": "20.4.2",
		"@commitlint/format": "20.4.0",
		"@commitlint/types": "20.4.0",
		"@eslint/js": "10.0.1",
		"@tailwindcss/postcss": "4.2.1",
		"@tailwindcss/vite": "4.2.1",
		"@types/cannon": "0.1.13",
		"@types/lodash": "4.17.24",
		"@types/markdown-it": "14.1.2",
		"@types/semver": "7.7.1",
		"@types/three": "0.183.1",
		"@typescript-eslint/eslint-plugin": "8.56.1",
		"@typescript-eslint/parser": "8.56.1",
		"@vitejs/plugin-legacy": "7.2.1",
		"@vitejs/plugin-vue": "6.0.4",
		"@vue/eslint-config-typescript": "14.7.0",
		"@vue/test-utils": "2.4.6",
		"commitlint": "20.4.2",
		"conventional-changelog-atom": "5.0.0",
		"cypress": "15.11.0",
		"cypress-file-upload": "5.0.8",
		"eslint": "10.0.2",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-vue": "10.8.0",
		"globals": "17.3.0",
		"husky": "9.1.7",
		"jsdom": "28.1.0",
		"lint-staged": "16.2.7",
		"prettier": "3.8.1",
		"prettier-plugin-sort-imports": "1.8.11",
		"prettier-plugin-sort-json": "4.2.0",
		"prettier-plugin-tailwindcss": "0.7.2",
		"semver": "7.7.4",
		"tailwindcss": "4.2.1",
		"terser": "5.46.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.56.1",
		"vite": "7.3.1",
		"vite-plugin-pwa": "1.2.0",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.0.18",
		"vue-tsc": "3.2.5"
	},
	"description": "FATE: Core - A digital character sheet for the FATE Core RPG system."
}
